<Window x:Class="Agilent34410A.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agilent 34410A - Digital Multimeter Control"
        Width="1300" Height="920" MinWidth="1100" MinHeight="750"
        Background="#1a2332" WindowState="Maximized"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Button Base -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Background" Value="#3d5a80"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4d6a90"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5d7aa0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E88E5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnStop" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#e53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#c62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnFunc" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2e7d32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#43a047" BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#388e3c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnFuncActive" TargetType="Button" BasedOn="{StaticResource BtnFunc}">
            <Setter Property="Background" Value="#43a047"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#81c784" BorderThickness="2" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4caf50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GroupBox - SOLID visible cards -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#64b5f6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border Grid.RowSpan="2" Background="#263248" BorderBrush="#3d6090" BorderThickness="1.5" CornerRadius="6"/>
                            <TextBlock Grid.Row="0" Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"
                                       Margin="12,8,12,2"/>
                            <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#d0dcea"/>
            <Setter Property="Foreground" Value="#1a1a2e"/>
            <Setter Property="BorderBrush" Value="#3d6090"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#d0dcea"/>
            <Setter Property="Foreground" Value="#1a1a2e"/>
            <Setter Property="BorderBrush" Value="#3d6090"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#1a1a2e"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e8f0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1e2d42"/>
            <Setter Property="Foreground" Value="#e8eaf0"/>
            <Setter Property="BorderBrush" Value="#3d6090"/>
            <Setter Property="RowBackground" Value="#1e2d42"/>
            <Setter Property="AlternatingRowBackground" Value="#243550"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2c4060"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2a4060"/>
            <Setter Property="Foreground" Value="#64b5f6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#3d6090"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2196F3"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Outer blue border frame -->
    <Border BorderBrush="#2962FF" BorderThickness="2" CornerRadius="0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection Bar -->
        <Border Grid.Row="0" Background="#1e3050" Padding="12,10" BorderBrush="#2962FF" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Resource:" Foreground="#90caf9" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbResource" Grid.Column="1" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="Refresh" Style="{StaticResource BtnBase}" Click="BtnRefresh_Click" Margin="0,0,6,0"/>
                <Button x:Name="btnConnect" Grid.Column="3" Content="Connect" Style="{StaticResource BtnAccent}" Click="BtnConnect_Click" Margin="0,0,12,0"/>
                <TextBlock x:Name="txtStatus" Grid.Column="4" Text="Disconnected" Foreground="#ef5350" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtIdn" Grid.Column="5" Foreground="#90a4ae" FontSize="10" VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="txtTerminals" Grid.Column="6" Foreground="#90a4ae" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Display -->
        <Border Grid.Row="1" Background="#060a10" Margin="12,8,12,4" CornerRadius="8" BorderBrush="#2962FF" BorderThickness="1.5">
            <Grid Margin="24,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtFunction" Text="DC Voltage" Foreground="#66bb6a" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtRelLabel" Text="" Foreground="#ffab40" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtRateDisplay" Text="" Foreground="#90caf9" FontFamily="Consolas" FontSize="12" Margin="16,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtValue" Text="---" Foreground="#00ff88" FontFamily="Consolas" FontSize="62" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,12">
                        <TextBlock x:Name="txtUnit" Text="" Foreground="#66ff99" FontFamily="Consolas" FontSize="26"/>
                        <TextBlock x:Name="txtDelta" Text="" Foreground="#ffab40" FontFamily="Consolas" FontSize="14" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Function Buttons + AUTO -->
        <Grid Grid.Row="2" Margin="12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <UniformGrid Rows="1" Columns="12">
                <Button x:Name="btnDCV" Content="DCV" Style="{StaticResource BtnFuncActive}" Click="BtnFunc_Click" Tag="DC Voltage" Margin="2"/>
                <Button x:Name="btnACV" Content="ACV" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="AC Voltage" Margin="2"/>
                <Button x:Name="btnDCI" Content="DCI" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="DC Current" Margin="2"/>
                <Button x:Name="btnACI" Content="ACI" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="AC Current" Margin="2"/>
                <Button x:Name="btnR2W" Content="&#937;2W" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="2W Resistance" Margin="2"/>
                <Button x:Name="btnR4W" Content="&#937;4W" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="4W Resistance" Margin="2"/>
                <Button x:Name="btnFreq" Content="FREQ" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="Frequency" Margin="2"/>
                <Button x:Name="btnPer" Content="PER" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="Period" Margin="2"/>
                <Button x:Name="btnCont" Content="CONT" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="Continuity" Margin="2"/>
                <Button x:Name="btnDiode" Content="DIODE" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="Diode" Margin="2"/>
                <Button x:Name="btnTemp" Content="TEMP" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="Temperature" Margin="2"/>
                <Button x:Name="btnCap" Content="CAP" Style="{StaticResource BtnFunc}" Click="BtnFunc_Click" Tag="Capacitance" Margin="2"/>
            </UniformGrid>
            <Button x:Name="btnAutoDetect" Grid.Column="1" Content="&#128269; AUTO" Style="{StaticResource BtnAccent}"
                    Click="BtnAutoDetect_Click" Margin="4,2" Padding="12,10" FontSize="11" FontWeight="Bold"/>
        </Grid>

        <!-- Control Bar -->
        <Border Grid.Row="3" Background="#1e3050" Margin="12,2,12,4" CornerRadius="6" Padding="10,8" BorderBrush="#3d6090" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnSingle" Content="&#9654; Single" Style="{StaticResource BtnAccent}" Click="BtnSingle_Click" Margin="0,0,6,0"/>
                <Button x:Name="btnStream" Content="&#9654; Stream" Style="{StaticResource BtnAccent}" Click="BtnStream_Click" Margin="0,0,6,0"/>
                <TextBlock Text="Interval (s):" Foreground="#90caf9" Margin="8,0,4,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtInterval" Text="0.5" Width="55" VerticalAlignment="Center"/>
                <Rectangle Width="1" Fill="#3d6090" Margin="14,2"/>
                <Button x:Name="btnDigitize" Content="&#9608; SCOPE" Style="{StaticResource BtnAccent}" Click="BtnDigitize_Click" Margin="14,0,6,0" FontWeight="Bold" Background="#00c853"/>
                <TextBlock Text="Cycles:" Foreground="#90caf9" Margin="4,0,4,0" VerticalAlignment="Center"/>
                <TextBox x:Name="txtScopeCycles" Text="8" Width="35" VerticalAlignment="Center"/>
                <TextBlock Text="T/div:" Foreground="#90caf9" Margin="10,0,4,0" VerticalAlignment="Center"/>
                <Slider x:Name="sldTimeBase" Width="100" Minimum="1" Maximum="100" Value="100" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" ToolTip="Time base - drag left to zoom in"/>
                <TextBlock x:Name="txtTimeBaseVal" Text="Auto" Foreground="#42a5f5" FontFamily="Consolas" FontSize="10" Margin="2,0,0,0" VerticalAlignment="Center" Width="45"/>
                <Rectangle Width="1" Fill="#3d6090" Margin="8,2"/>
                <TextBlock Text="Trig:" Foreground="#90caf9" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <Slider x:Name="sldTrigLevel" Width="80" Minimum="0" Maximum="100" Value="50" VerticalAlignment="Center" ToolTip="Trigger level"/>
                <CheckBox x:Name="chkCursors" Content="Cursors" Foreground="#90caf9" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <Slider x:Name="sldCursor1" Width="60" Minimum="0" Maximum="100" Value="25" VerticalAlignment="Center" Margin="6,0,0,0" ToolTip="Cursor 1" IsEnabled="{Binding IsChecked, ElementName=chkCursors}"/>
                <Slider x:Name="sldCursor2" Width="60" Minimum="0" Maximum="100" Value="75" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Cursor 2" IsEnabled="{Binding IsChecked, ElementName=chkCursors}"/>
                <TextBlock x:Name="txtCursorInfo" Text="" Foreground="#ffab40" FontFamily="Consolas" FontSize="9" Margin="6,0,0,0" VerticalAlignment="Center"/>
                <Rectangle Width="1" Fill="#3d6090" Margin="8,2"/>
                <Button x:Name="btnRecord" Content="&#9679; Record CSV" Style="{StaticResource BtnBase}" Click="BtnRecord_Click" Margin="14,0,6,0"/>
                <Button Content="Clear" Style="{StaticResource BtnBase}" Click="BtnClear_Click" Margin="0,0,6,0"/>
                <Button Content="Export" Style="{StaticResource BtnBase}" Click="BtnExport_Click"/>
                <TextBlock x:Name="txtRecording" Foreground="#ef5350" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main: Config + Data + Chart -->
        <Grid Grid.Row="4" Margin="12,0,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Config Panels -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel>
                    <GroupBox Header="Range">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Range:" Foreground="#e0e8f0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbRange" Grid.Column="1" Margin="0,0,6,0"/>
                                <Button Grid.Column="2" Content="Set" Style="{StaticResource BtnBase}" Click="BtnSetRange_Click" Padding="10,4"/>
                            </Grid>
                            <CheckBox x:Name="chkAutoRange" Content="Auto Range" IsChecked="True" Margin="0,6,0,0" Click="ChkAutoRange_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Integration Time">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="NPLC:" Foreground="#e0e8f0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbNplc" Grid.Column="1" Margin="0,0,6,0"/>
                                <Button Grid.Column="2" Content="Set" Style="{StaticResource BtnBase}" Click="BtnSetNplc_Click" Padding="10,4"/>
                            </Grid>
                            <CheckBox x:Name="chkAutoZero" Content="Auto Zero" IsChecked="True" Margin="0,6,0,0" Click="ChkAutoZero_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="grpImpedance" Header="Input Impedance">
                        <CheckBox x:Name="chkHighZ" Content="Auto (&gt;10 G&#937; on 0.1/1/10V)" Click="ChkHighZ_Click"/>
                    </GroupBox>

                    <GroupBox x:Name="grpBandwidth" Header="AC Bandwidth" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtBwLabel" Text="BW (Hz):" Foreground="#e0e8f0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbBandwidth" Grid.Column="1" Margin="0,0,6,0"/>
                            <Button Grid.Column="2" Content="Set" Style="{StaticResource BtnBase}" Click="BtnSetBandwidth_Click" Padding="10,4"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox x:Name="grpNull" Header="Null / Offset">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chkNull" Content="Enable" Click="ChkNull_Click" Margin="0,0,8,0"/>
                            <TextBox x:Name="txtNullValue" Grid.Column="1" Text="0" Margin="0,0,6,0"/>
                            <Button Grid.Column="2" Content="Set" Style="{StaticResource BtnBase}" Click="BtnSetNull_Click" Padding="10,4"/>
                        </Grid>
                    </GroupBox>

                    <!-- Alarm / Limits -->
                    <GroupBox Header="Alarm / Limits">
                        <StackPanel>
                            <CheckBox x:Name="chkAlarmEnable" Content="Enable Alarms" Margin="0,0,0,6" Click="ChkAlarmEnable_Click"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Hi:" Foreground="#ef5350" Margin="0,0,6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="txtAlarmHi" Grid.Column="1" Text="" Margin="0,0,8,0"/>
                                <TextBlock Text="Lo:" Foreground="#42a5f5" Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBox x:Name="txtAlarmLo" Grid.Column="3" Text=""/>
                            </Grid>
                            <CheckBox x:Name="chkAlarmBeep" Content="Beep on alarm" Margin="0,6,0,0"/>
                            <TextBlock x:Name="txtAlarmStatus" Text="" Foreground="#66bb6a" FontFamily="Consolas" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Relative / Delta Mode -->
                    <GroupBox Header="Relative Mode">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="chkRelEnable" Content="REL" Click="ChkRelEnable_Click" Margin="0,0,8,0"/>
                                <TextBox x:Name="txtRelRef" Grid.Column="1" Text="0" Margin="0,0,6,0"/>
                                <Button Grid.Column="2" Content="Capture" Style="{StaticResource BtnAccent}" Click="BtnRelCapture_Click" Padding="10,4"/>
                            </Grid>
                            <TextBlock x:Name="txtRelDelta" Text="" Foreground="#ffab40" FontFamily="Consolas" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="grpTemp" Header="Temperature Config" Visibility="Collapsed">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Probe:" Foreground="#e0e8f0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbProbe" Grid.Column="1" Margin="0,0,8,0"/>
                                <TextBlock Text="Type:" Foreground="#e0e8f0" Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbProbeType" Grid.Column="3"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Units:" Foreground="#e0e8f0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbTempUnit" Grid.Column="1"/>
                                <Button Grid.Column="3" Content="Apply" Style="{StaticResource BtnAccent}" Click="BtnApplyTemp_Click" Padding="10,4"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Trigger">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Source:" Foreground="#e0e8f0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cmbTrigSource" Grid.Column="1" Margin="0,0,8,0"/>
                                <TextBlock Text="Delay:" Foreground="#e0e8f0" Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtTrigDelay" Grid.Column="3" Text="AUTO"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Trig#:" Foreground="#e0e8f0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtTrigCount" Grid.Column="1" Text="1" Margin="0,0,8,0"/>
                                <TextBlock Text="Samp#:" Foreground="#e0e8f0" Grid.Column="2" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtSampCount" Grid.Column="3" Text="1" Margin="0,0,6,0"/>
                                <Button Grid.Column="4" Content="Apply" Style="{StaticResource BtnAccent}" Click="BtnApplyTrigger_Click" Padding="10,4"/>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Math / Statistics">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Func:" Foreground="#e0e8f0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbMath" Grid.Column="1" Margin="0,0,6,0"/>
                            <Button Grid.Column="2" Content="Apply" Style="{StaticResource BtnBase}" Click="BtnApplyMath_Click" Padding="10,4"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Data Grid + Stats + Scope -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="200"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Stats Bar -->
                <Border Background="#1e3050" CornerRadius="6" Padding="12,8" Margin="0,0,0,6" BorderBrush="#3d6090" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtStatCount" Text="Count: 0" Foreground="#90caf9" FontFamily="Consolas" FontSize="11" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtStatMin" Text="Min: ---" Foreground="#90caf9" FontFamily="Consolas" FontSize="11" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtStatMax" Text="Max: ---" Foreground="#90caf9" FontFamily="Consolas" FontSize="11" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtStatAvg" Text="Avg: ---" Foreground="#90caf9" FontFamily="Consolas" FontSize="11" Margin="0,0,20,0"/>
                        <TextBlock x:Name="txtStatPtp" Text="P-P: ---" Foreground="#90caf9" FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Oscilloscope Display -->
                <Border Grid.Row="1" Background="#020808" CornerRadius="6" BorderBrush="#2962FF" BorderThickness="1.5" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Scope header bar -->
                        <Border Background="#081410" Padding="8,4" BorderBrush="#0a3a28" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#00c853" CornerRadius="2" Padding="6,1" Margin="0,0,10,0">
                                    <TextBlock Text="SCOPE" Foreground="#000000" FontFamily="Consolas" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock x:Name="txtScopeFunc" Grid.Column="1" Text="" Foreground="#ffab40" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtScopePoints" Grid.Column="2" Text="" Foreground="#546e7a" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtScopeAmpl" Grid.Column="3" Text="" Foreground="#00e676" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" Margin="8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtScopeTime" Grid.Column="4" Text="" Foreground="#42a5f5" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" Margin="8,0" VerticalAlignment="Center"/>
                                <Button Grid.Column="5" Content="&#128247;" FontSize="12" Padding="4,0" Margin="8,0,0,0" Style="{StaticResource BtnBase}" Background="#1e3050" Click="BtnScopeScreenshot_Click" ToolTip="Save scope screenshot"/>
                            </Grid>
                        </Border>
                        <!-- Scope canvas with Y-axis labels -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Y-axis labels -->
                            <Canvas x:Name="yAxisCanvas" ClipToBounds="True" Background="#020808"/>
                            <!-- Main scope canvas -->
                            <Canvas x:Name="chartCanvas" Grid.Column="1" ClipToBounds="True" Background="#020808" Margin="0,2,4,2"/>
                        </Grid>
                        <!-- X-axis time labels -->
                        <Border Grid.Row="2" Background="#0a1a18" Padding="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Canvas x:Name="xAxisCanvas" Grid.Column="1" Height="16" ClipToBounds="True"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Data Grid + Log split -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="160"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="dataGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                              SelectionMode="Extended" VerticalScrollBarVisibility="Auto"
                              BorderThickness="1.5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Number}" Width="60"/>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="200"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding ValueStr}" Width="200">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80"/>
                            <DataGridTextColumn Header="Function" Binding="{Binding Function}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Debug Log (collapsible) -->
                    <Border x:Name="logPanel" Grid.Row="1" Background="#0a0e14" CornerRadius="4" BorderBrush="#3d6090" BorderThickness="1" Margin="0,4,0,0" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#1e3050" Padding="6,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SCPI Debug Log" Foreground="#ffab40" FontFamily="Consolas" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Clear" FontSize="9" Padding="6,1" Style="{StaticResource BtnBase}" Click="BtnClearLog_Click" Margin="0,0,4,0"/>
                                    <Button Grid.Column="2" Content="Hide" FontSize="9" Padding="6,1" Style="{StaticResource BtnBase}" Click="BtnToggleLog_Click"/>
                                </Grid>
                            </Border>
                            <ListBox x:Name="lstLog" Grid.Row="1" Background="#0a0e14" Foreground="#80cbc4" FontFamily="Consolas" FontSize="11" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Bottom System Bar -->
        <Border Grid.Row="5" Background="#1e3050" Padding="10,8" BorderBrush="#2962FF" BorderThickness="0,2,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Reset" Style="{StaticResource BtnBase}" Click="BtnReset_Click" Margin="0,0,4,0"/>
                    <Button Content="Self Test" Style="{StaticResource BtnBase}" Click="BtnSelfTest_Click" Margin="0,0,4,0"/>
                    <Button Content="Errors" Style="{StaticResource BtnBase}" Click="BtnErrors_Click" Margin="0,0,4,0"/>
                    <Button Content="Beep" Style="{StaticResource BtnBase}" Click="BtnBeep_Click" Margin="0,0,4,0"/>
                    <Button Content="Inst Info" Style="{StaticResource BtnAccent}" Click="BtnInstInfo_Click" Margin="0,0,20,0"/>
                    <TextBlock Text="Display:" Foreground="#90caf9" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtDisplayText" Width="130" MaxLength="12" VerticalAlignment="Center"/>
                    <Button Content="Set" Style="{StaticResource BtnBase}" Click="BtnSetDisplay_Click" Padding="8,4" Margin="4,0"/>
                    <Button Content="Clear" Style="{StaticResource BtnBase}" Click="BtnClearDisplay_Click" Padding="8,4"/>
                    <Button Content="SCPI Log" Style="{StaticResource BtnBase}" Click="BtnToggleLog_Click" Padding="8,4" Margin="20,0,0,0" Background="#37474f"/>
                </StackPanel>
                <!-- Alarm indicator -->
                <Border x:Name="alarmIndicator" Grid.Column="2" Background="Transparent" CornerRadius="4" Padding="10,4">
                    <TextBlock x:Name="txtAlarmIndicator" Text="" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="White"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
    </Border>
</Window>
